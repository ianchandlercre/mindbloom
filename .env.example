# ─── MindBloom AI Configuration ───────────────────────────────────────────────
#
# Copy this file to .env and add your keys. The app works fine without them
# (uses built-in content), but with a key you get AI-generated game content,
# personalized encouragement, and adaptive themes.
#
# The app tries Claude first. If no Anthropic key, falls to Gemini.
# Set ONE or BOTH — your call.

# Anthropic Claude API (preferred)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google Gemini API (fallback)
GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# ─── Database (Vercel Postgres / Neon) ────────────────────────────────────────
# Connect a Vercel Postgres database in the Vercel dashboard; it will inject
# these env vars automatically. Or create a free Neon database and set them.
POSTGRES_URL=your-postgres-connection-string

# ─── App Settings ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=MindBloom
NODE_ENV=production
